# Database
DATABASE_URL=postgresql://mediamanager:mediamanager@localhost:5432/mediamanager

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# API Keys
TMDB_API_KEY=
TVDB_API_KEY=
FANART_API_KEY=
SUBDL_API_KEY=
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# Media library root — mount this path into Docker so the backend can read your files
MEDIA_PATH=/media

# File storage
CACHE_DIR=./cache
UPLOAD_DIR=./uploads

# Security
JWT_SECRET=change-me-in-production
