    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "bullmq": "^5.7.8",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.10.4",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
